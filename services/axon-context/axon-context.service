[Unit]
Description=Axon OS AI Context Service
After=dbus.socket
Requires=dbus.socket

[Service]
Type=dbus
BusName=org.axonos.Context
ExecStart=/usr/bin/python3 AXON_SERVICES_DIR/axon-context/context_service.py
Restart=on-failure
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true

[Install]
WantedBy=default.target
