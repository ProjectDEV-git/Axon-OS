[Unit]
Description=Axon OS Voice (speech-to-intent) Service
After=graphical-session.target dbus.socket
PartOf=graphical-session.target
Requires=dbus.socket

[Service]
Type=dbus
BusName=org.axonos.Voice
ExecStart=/usr/bin/python3 AXON_SERVICES_DIR/axon-voice/voice_service.py
Restart=on-failure
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true

[Install]
WantedBy=graphical-session.target
