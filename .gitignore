# =============================================================================
# Axon OS .gitignore
# =============================================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.pyc
*.egg-info/
*.egg
.eggs/
wheels/
sdist/
develop-eggs/
dist/
lib/
lib64/
parts/
MANIFEST

# --- Virtual environments ---
venv/
.venv/
env/
.env/
ENV/
env.bak/
venv.bak/
test_env/

# --- Environment variables ---
.env
.env.local
.env.*.local

# --- Distribution / packaging ---
# build/ is KEPT — contains ISO build scripts
output/
*.iso

# --- Kernel build artifacts ---
kernel/**/*.o
kernel/**/*.ko
kernel/**/*.mod
kernel/**/*.mod.*
kernel/**/*.cmd
kernel/**/Module.symvers
kernel/**/modules.order
kernel/**/.module-common.o
kernel/**/*.order

# --- Testing ---
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# --- Type checking ---
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/

# --- Linting ---
.ruff_cache/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb

# --- Compiled extensions ---
*.so
*.dylib
*.dll

# --- Logs ---
*.log
*.log.*
logs/
wget-log
wget-log.*

# --- Temporary files ---
*.tmp
*.swp
*.swo
*~

# --- IDE - JetBrains ---
.idea/
*.iml
*.ipr
*.iws

# --- IDE - VSCode ---
.vscode/
*.code-workspace

# --- OS ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- Debug artifacts ---
debug-reports.zip
