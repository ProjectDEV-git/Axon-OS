#!/usr/bin/env bash
# Non-blocking reminder to bump version before releasing
set -e

latest_tag=$(git describe --tags --abbrev=0 2>/dev/null || echo "")
py_version=$(grep -m1 '^version' pyproject.toml | sed -E 's/version\s*=\s*"([^"]+)"/\1/')

if [ -n "$latest_tag" ] && [ "$py_version" = "${latest_tag#v}" ]; then
  echo "WARNING: pyproject.toml version ($py_version) matches latest tag ($latest_tag)."
  echo "Consider running: python scripts/bump_version.py <new-version>"
fi

exit 0
